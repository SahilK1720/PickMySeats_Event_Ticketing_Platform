# ─────────────────────────────────────────────────────────────
# PickMySeats Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://scantix:your_password@localhost:5432/scantix_db

# ── Redis ─────────────────────────────────────────────────────
# Used for rate limiting on purchase endpoints. Falls back gracefully if missing.
REDIS_URL=redis://127.0.0.1:6379

# ── Authentication ────────────────────────────────────────────
# Long, random string (e.g. openssl rand -base64 64)
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Server ───────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── CORS ─────────────────────────────────────────────────────
# URL of your Angular frontend (no trailing slash)
CORS_ORIGIN=http://localhost:4200

# ── Razorpay (Payment Gateway) ───────────────────────────────
# Get from Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── SMTP / Email ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@pickmyseats.app

# ── Application ───────────────────────────────────────────────
APP_BASE_URL=http://localhost:4200

# ── Logging ───────────────────────────────────────────────────
# Levels: error, warn, info, debug, trace
RUST_LOG=info
